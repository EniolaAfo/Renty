}

.listing__sidebar { margin-left: 10px; flex: 0 0 205px; }

.listing__intro { flex: 0 0 420px; }

.listing__details { margin-left: 30px; }

.listing-ref { flex-shrink: 0; border-radius: 0px 3px; padding: 11px 10px; =
background-color: rgba(0, 0, 0, 0.5); }

.listing-ref:has(span.new_today_listing) { background-color: rgb(255, 150, =
0); }

.header-utils { box-sizing: border-box; display: flex; justify-content: fle=
x-start; }

.header-utils--featured { max-width: unset; box-sizing: border-box; justify=
-content: flex-start; }

.header-utils__button:not(:last-child) { margin-right: 10px; }

.header-utils__button--hidden .button { background-color: rgb(153, 153, 153=
); color: rgb(255, 255, 255); box-shadow: none; }

.header-utils__button--saved .button { background-color: rgb(255, 1, 94); c=
olor: rgb(255, 255, 255); border-color: rgb(255, 1, 94); box-shadow: none; =
}

.header-utils__button--saved .button__icon .fas { padding: 0px; }

.share { display: inline-block; position: relative; bottom: -5px; margin-le=
ft: 8px; }

.share__container { display: flex; width: 210px; justify-content: space-aro=
und; }

