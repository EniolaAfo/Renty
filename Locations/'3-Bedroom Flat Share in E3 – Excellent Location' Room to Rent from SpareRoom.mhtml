ound: rgb(94, 94, 94); color: rgb(255, 255, 255); }

.feature { padding: 10px 0px; margin: 0px; }

.listing--bold .feature { border-color: rgb(20, 200, 246); }

.key-features { margin-bottom: 0px; list-style: none; margin-left: 0px; }

.key-features__feature { font-size: 16px; line-height: 20px; color: rgb(0, =
